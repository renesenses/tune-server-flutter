#!/bin/bash
# Anti-leak hook: prevent recording/special-edition references in public repo
FORBIDDEN="recorder|recording|special.edition|tune.special"

# Check staged files only
MATCHES=$(git diff --cached --name-only -z | xargs -0 grep -rlE "$FORBIDDEN" 2>/dev/null | while read -r f; do
  # Exclude false positives: MusicBrainz API uses "recording" as a core concept
  # Filter out all MusicBrainz-related recording references before checking
  if grep -E "$FORBIDDEN" "$f" | grep -vE 'musicbrainz|MusicBrainz|recording_id|recording[?/:"'"'"']|Recording[CI]|/recording/' | grep -qE "$FORBIDDEN"; then
    echo "$f"
  fi
done | grep -v '.githooks/' | grep -v 'CLAUDE.md' | grep -v '/metadata/')

# ── Drift codegen check ──
# If schema.dart was modified, verify database.g.dart is also staged
if git diff --cached --name-only | grep -q 'schema.dart'; then
    if ! git diff --cached --name-only | grep -q 'database.g.dart'; then
        echo "⚠️  WARNING: schema.dart modified but database.g.dart not staged."
        echo "   Run: dart run build_runner build --delete-conflicting-outputs"
        echo "   Then: git add lib/server/database/database.g.dart"
        exit 1
    fi
fi

if [ -n "$MATCHES" ]; then
    echo "🚫 BLOCKED: Forbidden terms found in staged files!"
    echo "   Pattern: $FORBIDDEN"
    echo ""
    for f in $MATCHES; do
        echo "   $f:"
        git diff --cached -- "$f" | grep -inE "$FORBIDDEN" | head -5 | sed 's/^/      /'
    done
    echo ""
    echo "   Remove these references before committing to the PUBLIC repo."
    exit 1
fi
